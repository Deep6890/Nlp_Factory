# ─────────────────────────────────────────────────────────────
#  Audio Storage + Transcript Backend
#  Copy this file to .env and fill in all values before running
# ─────────────────────────────────────────────────────────────

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────
# Set to your frontend origin or leave * for open access
CORS_ORIGIN=*

# ── MongoDB ────────────────────────────────────────────────────
# Get a free cluster at https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.mongodb.net/audio_transcript_db?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────
# Use a long random secret (min 32 chars). Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ── Cloudinary ─────────────────────────────────────────────────
# Free account at https://cloudinary.com
# Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Transcript Engine ──────────────────────────────────────────
# URL of your custom STT service endpoint.
# The engine must accept:
#   POST { audio_url: string }
# And respond with JSON:
#   { text, language, confidence, keywords, summary }
TRANSCRIPT_ENGINE_URL=https://your-transcript-engine.com/transcribe

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=20
